# Copy this file to .env and fill in real values for local development.
# In production (Render), set these as environment variables in the dashboard
# instead of committing a .env file.

ENVIRONMENT=development

# SQLite by default for zero-setup local dev. For production, use a Postgres
# URL, e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./teens_helpline.db

# Generate a strong random value for production, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list — add your deployed frontend URLs here in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# First-run admin account credentials — log in and change the password,
# or create new admins and deactivate this one, after first deploy.
DEFAULT_ADMIN_EMAIL=admin@teenshelpline.org
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123!
